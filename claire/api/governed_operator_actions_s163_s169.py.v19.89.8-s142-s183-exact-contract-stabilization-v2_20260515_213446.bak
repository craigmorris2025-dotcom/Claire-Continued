from __future__ import annotations

import json
from datetime import datetime, timezone
from pathlib import Path
from typing import Any, Dict, Mapping

from claire.api.governed_operational_cockpit_binding_s156_s162 import build_s156_s162_stop_gate
from claire.api.governed_functional_slice_s114_s120 import (
    build_approved_evidence_run_contract,
    build_governed_search_control_backend,
)
from claire.api.governed_review_queue import (
    enqueue_for_review,
    decide_review_item,
    list_review_queue,
)
from claire.api.governed_reviewed_exports import export_reviewed_output
from claire.api.governed_discovery_candidates import build_discovery_candidate
from claire.api.governed_useful_outputs import build_useful_output_candidate

LOCKS = {
    "backend_owns_truth": True,
    "cockpit_presentation_only": True,
    "runtime_truth_write_blocked": True,
    "runtime_truth_mutation_blocked": True,
    "automatic_updates_blocked": True,
    "autonomous_execution_blocked": True,
    "manual_promotion_mandatory": True,
    "quarantine_mandatory": True,
}

VALID_ACTIONS = ["approve", "reject", "archive", "export_only"]

def _utc_now() -> str:
    return datetime.now(timezone.utc).isoformat()

def _sample_output_candidate() -> Dict[str, Any]:
    evidence = {
        "basket_id": "s163_action_basket",
        "trust_score": 0.84,
        "evidence_items": [
            {"evidence_id": "s163_ev_001", "title": "Operator action candidate", "trust_score": 0.84}
        ],
    }
    extraction = {
        "extraction_id": "s163_action_extraction",
        "signals": [{"label": "operator action proof signal", "type": "portfolio", "confidence": 0.82}],
    }
    discovery = build_discovery_candidate(evidence, extraction, requested_route="portfolio")
    return build_useful_output_candidate(discovery)

def build_operator_action_contract() -> Dict[str, Any]:
    return {
        "stage_version": "S163",
        "status": "operator_action_contract_ready",
        "valid_actions": list(VALID_ACTIONS),
        "requires_operator_confirmation": True,
        "manual_operator_only": True,
        "runtime_truth_write": "blocked",
        "automatic_updates": "blocked",
        "autonomous_execution": "blocked",
        "locks": dict(LOCKS),
    }

def build_operator_review_action_preview(*, store_path: Path | None = None) -> Dict[str, Any]:
    output = _sample_output_candidate()
    item = enqueue_for_review(output, store_path=store_path, operator="s164_preview")
    queue = list_review_queue(store_path=store_path)
    return {
        "stage_version": "S164",
        "status": "operator_review_action_preview_ready",
        "review_item": item,
        "queue_total": len(queue.get("queue", [])),
        "available_actions": list(VALID_ACTIONS),
        "execution_performed": False,
        "runtime_truth_write": "blocked",
        "locks": dict(LOCKS),
    }

def execute_guarded_operator_action(
    review_item_id: str,
    action: str,
    *,
    store_path: Path | None = None,
    export_dir: Path | None = None,
    operator: str = "operator",
    note: str = "",
) -> Dict[str, Any]:
    normalized = action.strip().lower()
    if normalized not in VALID_ACTIONS:
        raise ValueError(f"action must be one of {VALID_ACTIONS}")
    decision = "approved" if normalized == "approve" else normalized
    decision_payload = decide_review_item(
        review_item_id,
        decision,
        store_path=store_path,
        operator=operator,
        note=note or f"S165 guarded operator action: {normalized}",
    )
    exported = None
    if normalized in {"approve", "export_only"}:
        exported = export_reviewed_output(decision_payload["review_item"], export_dir=export_dir, export_format="json")
    return {
        "stage_version": "S165",
        "status": "guarded_operator_action_complete",
        "action": normalized,
        "decision": decision_payload["decision"],
        "review_item": decision_payload["review_item"],
        "export": exported,
        "runtime_truth_write": "blocked",
        "runtime_truth_mutation": "blocked",
        "locks": dict(LOCKS),
    }

def build_operator_action_audit_trail(*, store_path: Path | None = None, export_dir: Path | None = None) -> Dict[str, Any]:
    preview = build_operator_review_action_preview(store_path=store_path)
    review_item_id = preview["review_item"]["review_item_id"]
    action = execute_guarded_operator_action(
        review_item_id,
        "approve",
        store_path=store_path,
        export_dir=export_dir,
        operator="s166_audit",
        note="S166 audit-trail approval proof.",
    )
    queue = list_review_queue(store_path=store_path)
    return {
        "stage_version": "S166",
        "status": "operator_action_audit_trail_ready",
        "preview": preview,
        "action": action,
        "queue_total": len(queue.get("queue", [])),
        "decision_total": len(queue.get("decisions", [])),
        "audit_events": [
            {"event": "review_item_created", "review_item_id": review_item_id},
            {"event": "operator_decision_recorded", "decision": action["decision"]["decision"]},
            {"event": "derived_export_created", "export": action["export"] is not None},
        ],
        "locks": dict(LOCKS),
    }

def build_export_lifecycle_proof(*, store_path: Path | None = None, export_dir: Path | None = None) -> Dict[str, Any]:
    audit = build_operator_action_audit_trail(store_path=store_path, export_dir=export_dir)
    export = audit["action"]["export"]
    export_exists = export is not None and Path(export["path"]).exists()
    return {
        "stage_version": "S167",
        "status": "export_lifecycle_proof_ready" if export_exists else "export_lifecycle_proof_failed",
        "ok": export_exists,
        "export": export,
        "derived_artifact_only": True,
        "runtime_truth_write": "blocked",
        "audit": audit,
        "locks": dict(LOCKS),
    }

def build_operator_action_rollback_contract() -> Dict[str, Any]:
    return {
        "stage_version": "S168",
        "status": "operator_action_rollback_contract_ready",
        "rollback_scope": {
            "review_queue": "decision records are append-only audit events",
            "exports": "derived artifact can be archived or ignored without mutating runtime truth",
            "runtime_truth": "no rollback required because no runtime truth write is performed",
        },
        "rollback_supported": True,
        "runtime_truth_write": "blocked",
        "locks": dict(LOCKS),
    }

def build_s163_s169_stop_gate(*, report_dir: Path | None = None, store_path: Path | None = None, export_dir: Path | None = None) -> Dict[str, Any]:
    previous = build_s156_s162_stop_gate()
    contract = build_operator_action_contract()
    preview = build_operator_review_action_preview(store_path=store_path)
    action = execute_guarded_operator_action(
        preview["review_item"]["review_item_id"],
        "approve",
        store_path=store_path,
        export_dir=export_dir,
        operator="s169_gate",
        note="S169 stop-gate approval proof.",
    )
    audit = build_operator_action_audit_trail(store_path=store_path, export_dir=export_dir)
    export_proof = build_export_lifecycle_proof(store_path=store_path, export_dir=export_dir)
    rollback = build_operator_action_rollback_contract()
    search_control = build_governed_search_control_backend()
    checks = {
        "previous_gate_ok": previous.get("ok") is True,
        "s163_contract_ready": contract["status"] == "operator_action_contract_ready",
        "s164_preview_ready": preview["status"] == "operator_review_action_preview_ready",
        "s165_action_complete": action["status"] == "guarded_operator_action_complete",
        "s166_audit_ready": audit["status"] == "operator_action_audit_trail_ready",
        "s167_export_lifecycle_ok": export_proof["ok"] is True,
        "s168_rollback_ready": rollback["status"] == "operator_action_rollback_contract_ready",
        "governed_search_still_blocked": search_control["automatic_updates"] == "blocked",
        "runtime_truth_write_blocked": action["runtime_truth_write"] == "blocked",
        "export_exists": action["export"] is not None and Path(action["export"]["path"]).exists(),
    }
    ok = all(checks.values())
    report = {
        "stage_version": "S169",
        "generated_at": _utc_now(),
        "status": "s163_s169_operator_actions_passed" if ok else "s163_s169_operator_actions_failed",
        "ok": ok,
        "functional_coverage": {
            "S163": "operator action contract",
            "S164": "operator review action preview",
            "S165": "guarded operator action execution",
            "S166": "operator action audit trail",
            "S167": "export lifecycle proof",
            "S168": "rollback contract",
            "S169": "operator action stop gate",
        },
        "checks": checks,
        "action": action,
        "audit": audit,
        "export_proof": export_proof,
        "rollback": rollback,
        "forward_motion_allowed": ok,
        "remaining_countdown": {
            "packs_remaining_after_this": 1,
            "next_pack": "S170-S176 controlled live fetch validation",
        },
        "next_allowed_phase": "S170 controlled live fetch validation" if ok else "repair S163-S169 failing check only",
    }
    if report_dir is not None:
        report_dir.mkdir(parents=True, exist_ok=True)
        path = report_dir / "s163_s169_operator_actions.json"
        path.write_text(json.dumps(report, indent=2, sort_keys=True), encoding="utf-8")
        report["report_path"] = str(path)
    return report
