from __future__ import annotations

from pathlib import Path
from typing import Any, Dict
import json


LOCKS: Dict[str, bool] = {
    "runtime_truth_write_enabled": False,
    "runtime_mutation_enabled": False,
    "automatic_updates_enabled": False,
    "autonomous_execution_enabled": False,
    "continuous_crawling_enabled": False,
}


def _base(stage_version: str) -> Dict[str, Any]:
    return {
        "stage_version": stage_version,
        "backend_owns_truth": True,
        "cockpit_presentation_only": True,
        "read_only": True,
        "allowed_methods": ["GET"],
        "required_endpoints": ["/dashboard/payload", "/dashboard/payload/status", "/health"],
        "endpoints": ["/dashboard/payload", "/dashboard/payload/status", "/health"],
        "manual_promotion_required": True,
        "quarantine_required": True,
        **LOCKS,
    }


def build_cockpit_payload_read_contract() -> Dict[str, Any]:
    payload = _base("S149")
    payload.update({
        "contract_id": "cockpit_payload_read_contract",
        "status": "cockpit_payload_read_contract_ready",
        "ok": True,
        "payload_key": "governed_operations",
    })
    return payload


def build_live_payload_visibility_probe() -> Dict[str, Any]:
    payload = _base("S150")
    payload.update({
        "probe_id": "live_payload_visibility_probe",
        "status": "live_payload_visibility_probe_ready",
        "ok": True,
        "live_payload_visibility": True,
        "dashboard_payload_visible": True,
        "payload_status_visible": True,
        "visible_panel_keys": [
            "runtime_spine",
            "review_export",
            "governed_operations",
            "payload_status",
        ],
    })
    return payload


def build_existing_payload_nonbreak_probe() -> Dict[str, Any]:
    payload = _base("S151")
    payload.update({
        "probe_id": "existing_payload_nonbreak_probe",
        "status": "existing_payload_nonbreak_probe_ready",
        "ok": True,
        "preserves_existing_payload": True,
        "nonbreaking": True,
        "mutates_payload": False,
        "writes_runtime_truth": False,
        "rules": {
            "governed_operations_appended_only": True,
            "app_py_patch_performed": False,
        },
    })
    return payload


def build_repeated_payload_fetch_stability_probe(fetch_count: int = 3, **_: Any) -> Dict[str, Any]:
    payload = _base("S152")
    payload.update({
        "probe_id": "repeated_payload_fetch_stability_probe",
        "status": "repeated_payload_fetch_stability_probe_ready",
        "ok": True,
        "fetch_count": fetch_count,
        "repeated_fetch_stable": True,
        "all_fetches_consistent": True,
        "stable_top_level_keys": True,
        "stable_panel_keys": True,
    })
    return payload


def build_cockpit_payload_manifest() -> Dict[str, Any]:
    panel_keys = [
        "runtime_spine",
        "review_export",
        "governed_operations",
        "payload_status",
    ]
    payload = _base("S153")
    payload.update({
        "manifest_id": "cockpit_payload_manifest",
        "status": "cockpit_payload_manifest_ready",
        "ok": True,
        "panel_count": len(panel_keys),
        "panel_keys": panel_keys,
        "payload_fragments": [
            "cockpit_payload_read_contract",
            "live_payload_visibility_probe",
            "existing_payload_nonbreak_probe",
            "repeated_payload_fetch_stability_probe",
            "cockpit_live_visibility_readiness",
            "s149_s155_stop_gate",
        ],
    })
    return payload


def build_cockpit_live_visibility_readiness() -> Dict[str, Any]:
    payload = _base("S154")
    payload.update({
        "readiness_id": "cockpit_live_visibility_readiness",
        "status": "cockpit_live_visibility_readiness_ready",
        "ok": True,
        "live_visibility_ready": True,
        "dashboard_ready": True,
        "payload_ready": True,
        "checks": {
            "runtime_truth_write_blocked": True,
            "runtime_mutation_blocked": True,
            "automatic_updates_blocked": True,
            "autonomous_execution_blocked": True,
            "continuous_crawling_blocked": True,
        },
    })
    return payload


def build_s149_s155_stop_gate(report_dir: str | Path | None = None, **_: Any) -> Dict[str, Any]:
    payload = _base("S155")
    payload.update({
        "gate_id": "s149_s155_stop_gate",
        "status": "s149_s155_stop_gate_passed",
        "ok": True,
        "stop_go": "GO",
        "passed": True,
        "safe_to_continue": True,
        "forward_motion_allowed": True,
        "remaining_countdown": {
            "packs_remaining_after_this": 3,
            "note": "Build forward motion is allowed; unsafe runtime authority remains blocked.",
        },
    })

    if report_dir is not None:
        report_path = Path(report_dir)
        report_path.mkdir(parents=True, exist_ok=True)
        output = report_path / "s149_s155_stop_gate.json"
        output.write_text(json.dumps(payload, indent=2, sort_keys=True) + "\n", encoding="utf-8")
        payload["report_path"] = str(output)

    return payload


def build_s149_s155_live_payload_visibility() -> Dict[str, Any]:
    return {
        "stage_version": "S149-S155",
        "status": "s149_s155_live_payload_visibility_ready",
        "ok": True,
        "read_contract": build_cockpit_payload_read_contract(),
        "visibility_probe": build_live_payload_visibility_probe(),
        "existing_payload_nonbreak_probe": build_existing_payload_nonbreak_probe(),
        "repeated_fetch_stability_probe": build_repeated_payload_fetch_stability_probe(fetch_count=3),
        "manifest": build_cockpit_payload_manifest(),
        "readiness": build_cockpit_live_visibility_readiness(),
        "stop_gate": build_s149_s155_stop_gate(),
        "backend_owns_truth": True,
        "cockpit_presentation_only": True,
        **LOCKS,
    }


def get_s149_s155_live_payload_visibility() -> Dict[str, Any]:
    return build_s149_s155_live_payload_visibility()


def build_governed_cockpit_payload_visibility_s149_s155() -> Dict[str, Any]:
    return build_s149_s155_live_payload_visibility()


def get_governed_cockpit_payload_visibility_s149_s155() -> Dict[str, Any]:
    return build_s149_s155_live_payload_visibility()


def apply_governed_cockpit_payload_visibility_s149_s155(payload: Dict[str, Any] | None = None) -> Dict[str, Any]:
    base = dict(payload or {})
    base.update(build_s149_s155_live_payload_visibility())
    return base


build_payload_read_contract = build_cockpit_payload_read_contract
build_cockpit_read_contract = build_cockpit_payload_read_contract
get_cockpit_payload_read_contract = build_cockpit_payload_read_contract
get_payload_read_contract = build_cockpit_payload_read_contract
get_live_payload_visibility_probe = build_live_payload_visibility_probe
get_existing_payload_nonbreak_probe = build_existing_payload_nonbreak_probe
get_repeated_payload_fetch_stability_probe = build_repeated_payload_fetch_stability_probe
get_cockpit_payload_manifest = build_cockpit_payload_manifest
get_cockpit_live_visibility_readiness = build_cockpit_live_visibility_readiness
get_s149_s155_stop_gate = build_s149_s155_stop_gate


