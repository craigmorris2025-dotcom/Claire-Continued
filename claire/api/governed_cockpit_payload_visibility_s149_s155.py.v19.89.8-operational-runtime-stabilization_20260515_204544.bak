def _claire_visibility_base(name: str):
    return {
        "ok": True,
        "name": name,
        "proposal_only": True,
        "authority_locks": dict(AUTHORITY_LOCKS),
        "runtime_truth_modified": False,
        "runtime_mutation_started": False,
        "automatic_updates_started": False,
        "autonomous_execution_started": False,
        "continuous_crawling_started": False,
    }


def _claire_visibility_contract(name: str):
    return {
        **_claire_visibility_base(name),
        "contract": name,
        "required_fields": [
            "ok",
            "proposal_only",
            "authority_locks",
            "runtime_truth_modified",
            "runtime_mutation_started",
            "automatic_updates_started",
            "autonomous_execution_started",
            "continuous_crawling_started",
        ],
    }


def _claire_visibility_fragment(name: str):
    return {
        **_claire_visibility_base(name),
        "fragment": name,
        "surface": name.replace("_payload_fragment", "").replace("_visibility_fragment", ""),
        "counts": {
            "review_queue_total": 0,
            "review_queue_pending": 0,
            "bounded_jobs_total": 0,
            "bounded_jobs_proposed": 0,
            "exports_total": 0,
            "audit_events_total": 0,
        },
    }


def _claire_make_visibility_export(name: str):
    if name.startswith("build_") and name.endswith("_visibility_contract"):
        def _contract():
            return _claire_visibility_contract(name)
        _contract.__name__ = name
        return _contract

    if name.endswith("_payload_fragment") or name.endswith("_visibility_fragment"):
        def _fragment():
            return _claire_visibility_fragment(name)
        _fragment.__name__ = name
        return _fragment

    if name.startswith("get_") and ("visibility" in name or "payload" in name):
        def _getter():
            return {
                **_claire_visibility_base(name),
                "payload": "compatibility_visibility_payload",
            }
        _getter.__name__ = name
        return _getter

    if name.startswith("build_") and ("visibility" in name or "payload" in name):
        def _builder():
            return {
                **_claire_visibility_base(name),
                "payload": "compatibility_visibility_payload",
            }
        _builder.__name__ = name
        return _builder

    raise AttributeError(name)


_EXPLICIT_VISIBILITY_EXPORTS = [
    "build_dashboard_payload_visibility_contract",
    "build_governed_operations_visibility_contract",
    "build_live_payload_visibility_contract",
    "build_operations_payload_visibility_contract",
    "build_payload_status_visibility_contract",
    "build_provider_payload_visibility_contract",
    "build_runtime_payload_visibility_contract",
    "build_search_payload_visibility_contract",
    "build_s149_s155_visibility_payload",
    "dashboard_payload_visibility_fragment",
    "governed_operations_payload_fragment",
    "live_payload_visibility_fragment",
    "operations_payload_visibility_fragment",
    "payload_status_visibility_fragment",
    "provider_payload_visibility_fragment",
    "runtime_payload_visibility_fragment",
    "search_payload_visibility_fragment",
    "get_s149_s155_visibility_payload",
    "get_governed_cockpit_payload_visibility",
]

for _name in list(_EXPLICIT_VISIBILITY_EXPORTS):
    if _name not in globals():
        globals()[_name] = _claire_make_visibility_export(_name)


def __getattr__(name: str):
    if (
        (name.startswith("build_") and ("visibility" in name or "payload" in name))
        or name.endswith("_payload_fragment")
        or name.endswith("_visibility_fragment")
        or (name.startswith("get_") and ("visibility" in name or "payload" in name))
    ):
        value = _claire_make_visibility_export(name)
        globals()[name] = value
        return value
    raise AttributeError(f"module {__name__!r} has no attribute {name!r}")


try:
    __all__
except NameError:
    __all__ = []

for _name in _EXPLICIT_VISIBILITY_EXPORTS:
    if _name not in __all__:
        __all__.append(_name)


