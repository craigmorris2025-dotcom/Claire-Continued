
try:
    from claire.api.governed_timeline_classification import classify_timeline
except Exception:
    classify_timeline = None

from __future__ import annotations

from datetime import datetime, timezone
from pathlib import Path
from typing import Any, Dict, List
import json


ROOT = Path(__file__).resolve().parents[2]
TIMELINE_DIR = ROOT / "output" / "timeline"
TIMELINE_STATE_FILE = TIMELINE_DIR / "governed_runtime_timeline_state.json"


def _utc_now() -> str:
    return datetime.now(timezone.utc).isoformat()


def _safe_read_json(path: Path, default: Any) -> Any:
    try:
        if path.exists():
            return json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        return default
    return default


def _safe_write_json(path: Path, payload: Any) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(payload, indent=2, ensure_ascii=False), encoding="utf-8")


def _extract_payload_state(payload: Dict[str, Any]) -> Dict[str, Any]:
    runtime = payload.get("runtime") if isinstance(payload.get("runtime"), dict) else {}
    governance = payload.get("governance") if isinstance(payload.get("governance"), dict) else {}
    surface = payload.get("surface") if isinstance(payload.get("surface"), dict) else {}
    sidebar = payload.get("sidebar") if isinstance(payload.get("sidebar"), dict) else {}
    telemetry = payload.get("telemetry") if isinstance(payload.get("telemetry"), dict) else {}
    event_stream = payload.get("event_stream") if isinstance(payload.get("event_stream"), dict) else {}

    route = runtime.get("route") or runtime.get("selected_route") or payload.get("route") or payload.get("selected_route") or "unknown"
    terminal_state = runtime.get("terminal_state") or payload.get("terminal_state") or "unknown"
    connection_state = payload.get("connection_state") or telemetry.get("connection_state") or surface.get("connection_state") or "unknown"
    freshness = payload.get("freshness") or telemetry.get("freshness") or payload.get("payload_freshness") or "unknown"

    return {
        "route": route,
        "terminal_state": terminal_state,
        "connection_state": connection_state,
        "freshness": freshness,
        "runtime_authority": governance.get("runtime_authority", "blocked"),
        "backend_owns_truth": governance.get("backend_owns_truth", True),
        "fail_closed": governance.get("fail_closed", True),
        "surface_count": len(surface) if isinstance(surface, dict) else 0,
        "sidebar_count": len(sidebar) if isinstance(sidebar, dict) else 0,
        "event_count": len(event_stream.get("events", [])) if isinstance(event_stream, dict) and isinstance(event_stream.get("events"), list) else 0,
    }


def _change_events(previous: Dict[str, Any], current: Dict[str, Any]) -> List[Dict[str, Any]]:
    events: List[Dict[str, Any]] = []
    watched = [
        ("route", "runtime_state_transition"),
        ("terminal_state", "runtime_state_transition"),
        ("connection_state", "synchronization_change"),
        ("freshness", "payload_freshness_change"),
        ("runtime_authority", "governance_state"),
        ("event_count", "event_stream_evolution"),
    ]

    for key, event_type in watched:
        if previous.get(key) != current.get(key):
            events.append({
                "id": f"{event_type}:{key}:{_utc_now()}",
                "timestamp": _utc_now(),
                "type": event_type,
                "field": key,
                "from": previous.get(key, "unknown"),
                "to": current.get(key, "unknown"),
                "authority": "backend_projection",
                "runtime_authority": "blocked",
                "presentation_only": True,
            })

    if not events:
        events.append({
            "id": f"heartbeat:{_utc_now()}",
            "timestamp": _utc_now(),
            "type": "governed_observability_heartbeat",
            "field": "timeline",
            "from": "stable",
            "to": "stable",
            "authority": "backend_projection",
            "runtime_authority": "blocked",
            "presentation_only": True,
        })

    return events


def project_governed_runtime_timeline(payload: Dict[str, Any] | None = None) -> Dict[str, Any]:
    payload = payload if isinstance(payload, dict) else {}
    state = _safe_read_json(TIMELINE_STATE_FILE, {})
    previous_snapshot = state.get("last_snapshot") if isinstance(state.get("last_snapshot"), dict) else {}
    current_snapshot = _extract_payload_state(payload)
    new_events = _change_events(previous_snapshot, current_snapshot)
    existing_events = state.get("events") if isinstance(state.get("events"), list) else []
    merged_events = (existing_events + new_events)[-150:]

    timeline = {
        "version": "v19.89.8-S14",
        "status": "active",
        "authority": {
            "backend_owns_truth": True,
            "cockpit_presentation_only": True,
            "runtime_authority": "blocked",
            "fail_closed_governance": True,
            "autonomous_execution_expansion": False,
        },
        "summary": {
            "event_total": len(merged_events),
            "last_updated_utc": _utc_now(),
            "last_route": current_snapshot.get("route"),
            "last_terminal_state": current_snapshot.get("terminal_state"),
            "last_connection_state": current_snapshot.get("connection_state"),
            "last_payload_freshness": current_snapshot.get("freshness"),
        },
        "tracked_dimensions": [
            "runtime_state_transitions",
            "event_stream_evolution",
            "synchronization_changes",
            "payload_freshness_changes",
            "route_degradation_recovery",
        ],
        "events": merged_events,
        "last_snapshot": current_snapshot,
    }

    if classify_timeline:
        timeline = classify_timeline(timeline)
    _safe_write_json(TIMELINE_STATE_FILE, timeline)
    return timeline


def attach_governed_runtime_timeline(payload: Dict[str, Any]) -> Dict[str, Any]:
    if not isinstance(payload, dict):
        payload = {}
    payload["governed_runtime_timeline"] = project_governed_runtime_timeline(payload)
    return payload


def register_governed_runtime_timeline_routes(app: Any) -> None:
    try:
        from fastapi import APIRouter
    except Exception:
        return

    router = APIRouter(prefix="/api/governed/runtime", tags=["Governed Runtime Timeline"])

    @router.get("/timeline")
    def get_governed_runtime_timeline() -> Dict[str, Any]:
        return project_governed_runtime_timeline({})

    @router.get("/timeline/status")
    def get_governed_runtime_timeline_status() -> Dict[str, Any]:
        timeline = _safe_read_json(TIMELINE_STATE_FILE, {})
        return {
            "version": "v19.89.8-S14",
            "status": "active",
            "runtime_authority": "blocked",
            "presentation_only": True,
            "event_total": len(timeline.get("events", [])) if isinstance(timeline.get("events"), list) else 0,
            "last_updated_utc": timeline.get("summary", {}).get("last_updated_utc") if isinstance(timeline.get("summary"), dict) else None,
        }

    app.include_router(router)
