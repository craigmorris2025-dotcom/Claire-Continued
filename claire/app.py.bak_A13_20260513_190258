                        removed[path].append({
                            "name": getattr(route, "name", ""),
                            "endpoint": _claire_v19_88_8B_endpoint_name(route),
                            "methods": _claire_v19_88_8B_route_methods(route),
                        })

        locked = []
        for route in list(getattr(app.router, "routes", []) or []):
            path = getattr(route, "path", None)
            if path in selected:
                if route is selected[path]:
                    locked.append(route)
            else:
                locked.append(route)

        app.router.routes = locked
        app.state.claire_v19_88_8B_route_owner_lock = {
            "enabled": True,
            "canonical_paths": sorted(list(_CLAIRE_V19_88_8B_CANONICAL_ROUTE_OWNERS.keys())),
