def _claire_a10_inject_html_beacon(html: str) -> str:
    if _CLAIRE_A10_BEACON_MARKER in html:
        return html
    if "</body>" in html:
        return html.replace("</body>", _CLAIRE_A10_BEACON_SCRIPT + "\n</body>", 1)
    if "</html>" in html:
        return html.replace("</html>", _CLAIRE_A10_BEACON_SCRIPT + "\n</html>", 1)
    return html + "\n" + _CLAIRE_A10_BEACON_SCRIPT

async def _claire_a10_read_response_body(response) -> bytes:
    body = b""
    async for chunk in response.body_iterator:
        body += chunk
    return body

