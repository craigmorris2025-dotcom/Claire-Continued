    "src/frontend/command_center/modern/recursive_feedback_status.json"
  ],
  "required_fields": [
    "schema",
    "contract_version",
    "generated_at",
    "run_id",
    "route_selected",
    "terminal_state",
    "recursive_feedback_allowed",
    "feedback_status",
    "feedback_blockers",
    "feedback_reasons",
    "feedback_payload",
