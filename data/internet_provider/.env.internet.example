# Claire Internet Provider Example
# Do not paste real API keys into ChatGPT.
# Copy needed lines into your local .env only.

# Recommended Claire provider stack:
# - Brave: primary public web metadata provider when keyed.
# - Search.gov: government/public-sector metadata lane when affiliate/access key are configured.
# - DuckDuckGo: fallback-only, disabled for internal enterprise-grade research unless explicitly allowed.
CLAIRE_SEARCH_PROVIDER_STACK=brave,searchgov,duckduckgo
CLAIRE_SEARCH_PROVIDER=provider_stack
CLAIRE_ALLOW_REAL_SEARCH_PROVIDER=1
# CLAIRE_ALLOW_DUCKDUCKGO_FALLBACK=1

# Fallback-only option, not recommended for research/engineering-grade internal results:
# CLAIRE_SEARCH_PROVIDER=duckduckgo
# CLAIRE_ALLOW_REAL_SEARCH_PROVIDER=1
# CLAIRE_ALLOW_DUCKDUCKGO_FALLBACK=1

# CLAIRE_SEARCH_PROVIDER=searchgov
# SEARCHGOV_AFFILIATE=your_searchgov_site_handle
# SEARCHGOV_ACCESS_KEY=your_searchgov_access_key
# CLAIRE_ALLOW_REAL_SEARCH_PROVIDER=1

# CLAIRE_SEARCH_PROVIDER=brave
# BRAVE_SEARCH_API_KEY=your_key_here
# CLAIRE_ALLOW_REAL_SEARCH_PROVIDER=1

# CLAIRE_SEARCH_PROVIDER=bing
# BING_SEARCH_API_KEY=your_key_here
# CLAIRE_ALLOW_REAL_SEARCH_PROVIDER=1

# CLAIRE_SEARCH_PROVIDER=serpapi
# SERPAPI_API_KEY=your_key_here
# CLAIRE_ALLOW_REAL_SEARCH_PROVIDER=1

# CLAIRE_SEARCH_PROVIDER=tavily
# TAVILY_API_KEY=your_key_here
# CLAIRE_ALLOW_REAL_SEARCH_PROVIDER=1
