{
  "version": "4.0.0",
  "platform": "Claire Syntalion",
  "default_mode": "deterministic",
  "pipeline": {
    "phases": 6,
    "engines": 24,
    "timeout_seconds": 120
  },
  "scoring": {
    "go_threshold": 0.65,
    "caution_threshold": 0.35,
    "confidence_minimum": 0.25,
    "breakthrough_high": 0.70,
    "breakthrough_moderate": 0.40
  },
  "connectors": {
    "market": true,
    "patent": true,
    "financial": true
  },
  "bridge": {
    "readiness_threshold": 0.55,
    "confidence_minimum": 0.30
  },
  "governance": {
    "audit_enabled": true,
    "policy_enforcement": true
  }
}
