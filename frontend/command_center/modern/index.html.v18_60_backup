<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Claire Syntalion — Workspace Operator Cockpit</title>
  <link rel="stylesheet" href="claire_workspace_agent_dashboard.css" />
</head>
<body>
  <aside class="sidebar">
    <div class="brand">
      <div class="logo">C</div>
      <div>
        <h1>Claire</h1>
        <p>Workspace Operator Cockpit</p>
      </div>
    </div>

    <nav>
      <button data-workspace="mission" class="active">Mission</button>
      <button data-workspace="routes">Routes</button>
      <button data-workspace="discovery">Discovery</button>
      <button data-workspace="autodesign">AutoDesign</button>
      <button data-workspace="design_portal">Design Portal</button>
      <button data-workspace="portfolio">Portfolio</button>
      <button data-workspace="acquisition">Acquisition</button>
      <button data-workspace="internet">Internet</button>
      <button data-workspace="updates">Updates</button>
      <button data-workspace="proof">Proof</button>
      <button data-workspace="diagnostics">Diagnostics</button>
    </nav>

    <div class="lock-card">
      <span>Agent path</span>
      <strong>Prepared / governed</strong>
      <p>Search bar stays permanent. Web + command + agent behavior remain gated by source trust, evidence, and operator review.</p>
    </div>
  </aside>

  <main class="workspace">
    <header class="topbar">
      <div class="command-wrap">
        <select id="modeSelect" title="Search mode">
          <option value="runtime">Claire Runtime</option>
          <option value="web">Web</option>
          <option value="research">Governed Research</option>
          <option value="command">Command</option>
          <option value="agent">Agent</option>
        </select>
        <input id="commandSearch" placeholder="Search web, ask Claire, run command, or find system output..." />
        <button id="runSearch">Search</button>
      </div>
      <div id="backendStatus" class="status-pill offline">Backend offline</div>
    </header>

    <section class="hero">
      <div>
        <p class="eyebrow">Main operator state</p>
        <h2 id="missionTitle">Claire Syntalion</h2>
        <p id="missionSummary">Dashboard is waiting for backend state.</p>
      </div>
      <div class="hero-actions">
        <button data-action="refresh">Refresh</button>
        <button data-workspace-jump="proof">Proof</button>
        <button data-workspace-jump="internet">Internet</button>
      </div>
    </section>

    <section id="searchResultsPanel" class="search-results hidden">
      <div class="panel-head">
        <p class="eyebrow">Command/Search Results</p>
        <button id="closeSearch">Close</button>
      </div>
      <div id="searchResults"></div>
    </section>

    <section id="scorecards" class="scorecards"></section>

    <section id="mission" class="panel visible" data-title="Mission">
      <div class="panel-head"><p class="eyebrow">Mission</p><span id="stopGoStatus">not loaded</span></div>
      <h3>Current route and next safe action</h3>
      <div id="missionCards" class="cards"></div>
    </section>

    <section id="routes" class="panel" data-title="Routes">
      <div class="panel-head"><p class="eyebrow">Route Gate</p><span id="routeFamily">not loaded</span></div>
      <h3>Discovery → Thesis → Route</h3>
      <div id="routeCards" class="cards"></div>
    </section>

    <section id="discovery" class="panel" data-title="Discovery">
      <div class="panel-head"><p class="eyebrow">Discovery</p><span>first-class route</span></div>
      <h3>Signals, trends, thesis, discovery, innovation</h3>
      <div id="discoveryCards" class="cards"></div>
    </section>

    <section id="autodesign" class="panel" data-title="AutoDesign">
      <div class="panel-head"><p class="eyebrow">AutoDesign</p><span id="autodesignStatus">not loaded</span></div>
      <h3>Invention / system design handoff</h3>
      <div id="autodesignCards" class="cards"></div>
    </section>

    <section id="design_portal" class="panel" data-title="Design Portal">
      <div class="panel-head"><p class="eyebrow">Design Portal</p><span id="designPortalStatus">not loaded</span></div>
      <h3>Blueprint, components, technology stack</h3>
      <div id="designPortalCards" class="cards"></div>
    </section>

    <section id="portfolio" class="panel" data-title="Portfolio">
      <div class="panel-head"><p class="eyebrow">Portfolio</p><span>route output</span></div>
      <h3>Portfolio intelligence</h3>
      <div id="portfolioCards" class="cards"></div>
    </section>

    <section id="acquisition" class="panel" data-title="Acquisition">
      <div class="panel-head"><p class="eyebrow">Acquisition</p><span>package route</span></div>
      <h3>Acquisition and final package</h3>
      <div id="acquisitionCards" class="cards"></div>
    </section>

    <section id="internet" class="panel" data-title="Internet">
      <div class="panel-head"><p class="eyebrow">Internet</p><span id="internetStatus">not loaded</span></div>
      <h3>Web search readiness and governed research</h3>
      <div id="internetCards" class="cards"></div>
    </section>

    <section id="updates" class="panel" data-title="Updates">
      <div class="panel-head"><p class="eyebrow">Updates</p><span id="updatesStatus">guarded</span></div>
      <h3>Governed update preparation</h3>
      <div id="updatesCards" class="cards"></div>
    </section>

    <section id="proof" class="panel" data-title="Proof">
      <div class="panel-head"><p class="eyebrow">Proof</p><span id="proofStatus">not loaded</span></div>
      <h3>End-to-end proof and Stop/Go</h3>
      <div id="proofCards" class="cards"></div>
    </section>

    <section id="diagnostics" class="panel" data-title="Diagnostics">
      <div class="panel-head"><p class="eyebrow">Diagnostics</p><span id="diagnosticsStatus">waiting</span></div>
      <h3>Raw dashboard state</h3>
      <pre id="diagnosticsJson">{}</pre>
    </section>
  </main>

  <aside id="contextDrawer" class="context">
    <div class="panel-head">
      <p class="eyebrow">Context Drawer</p>
      <button id="drawerToggle">Hide</button>
    </div>
    <h3>Evidence / Details</h3>
    <div id="contextBody">Select a workspace or run a search.</div>
  </aside>

  <script src="claire_workspace_agent_dashboard.js"></script>
</body>
</html>
