PLATFORM_ENV=development
PLATFORM_PORT=8000
PLATFORM_HOST=127.0.0.1
PLATFORM_LOG_LEVEL=INFO
PLATFORM_CORS_ORIGINS=*
PLATFORM_DATA_DIR=data
PLATFORM_LOG_DIR=logs
PLATFORM_OUTPUT_DIR=output
PLATFORM_MARKET_API_KEY=
PLATFORM_PATENT_API_KEY=
PLATFORM_FINANCIAL_API_KEY=
PLATFORM_NEWS_API_KEY=

# Internet Activation
# Search/Enter in the cockpit is governed research intake: metadata results are
# quarantined before evidence promotion. Open-page inspection is separate.
PLATFORM_SEARCH_PROVIDER=brave
PLATFORM_SEARCH_PROVIDER_STACK=brave,searchgov,duckduckgo
PLATFORM_ALLOW_REAL_SEARCH_PROVIDER=1
PLATFORM_ALLOW_DUCKDUCKGO_FALLBACK=1
TAVILY_API_KEY=
BRAVE_SEARCH_API_KEY=
SERPAPI_API_KEY=
BING_SEARCH_API_KEY=
SEARCHGOV_AFFILIATE=
SEARCHGOV_ACCESS_KEY=
PLATFORM_INTERNET_MAX_RESULTS=5
PLATFORM_INTERNET_MAX_BYTES=750000
PLATFORM_INTERNET_TIMEOUT_SECONDS=15
PLATFORM_INTERNET_ALLOW_UNKNOWN_DOMAINS=false
